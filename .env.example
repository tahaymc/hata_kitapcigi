# ============================================================
# Ana site (api/index.js) için environment değişkenleri
# ============================================================

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# Bot entegrasyonu (admin panelinin botla konuşabilmesi için)
# ============================================================

# Bot HTTP admin sunucusu (örn. sanal sunucu IP'si)
# Yerel geliştirmede: http://localhost:3002
BOT_INTERNAL_URL=http://localhost:3002

# Bot ile paylaşılan gizli token. Hem ana site (.env) hem de bot (.env)
# bu değeri AYNI tutmalı.
BOT_SHARED_TOKEN=change-me-to-a-long-random-string
