# Bot HTTP server (kendi admin endpoint'leri)
PORT=3000
ADMIN_PORT=3002
NODE_ENV=development

# Ana siteye bağlantı (Supabase yerine API kullanılıyor)
SITE_API_URL=http://localhost:3001
# Bot'un WhatsApp yanıtlarındaki "detaylı çözüm" link'inde kullanılacak public URL.
# Boş bırakılırsa SITE_API_URL kullanılır. Production'da Vercel URL'i girin:
# SITE_PUBLIC_URL=https://siteniz.vercel.app
SITE_PUBLIC_URL=
# Bot, kendisini ana siteye tanıtmak ve admin endpoint'lerini korumak için bu token'ı kullanır.
# Ana site (.env) ile aynı olmalı: BOT_SHARED_TOKEN
BOT_SHARED_TOKEN=change-me-to-a-long-random-string

# Redis
# Seçenek A — Upstash veya bulut Redis (TLS):
#   REDIS_URL=rediss://default:PASSWORD@xxx.upstash.io:6379
# Seçenek B — Yerel Redis (Memurai/Docker):
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=true   # Manuel TLS açmak için

# WhatsApp oturum klasörü
SESSION_DIR=./auth_info_baileys

# Ayar/önbellek tazeleme aralığı (ms)
SETTINGS_REFRESH_MS=30000
HEARTBEAT_INTERVAL_MS=15000
