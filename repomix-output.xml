import Tesseract from 'tesseract.js';
import sharp from 'sharp';
import fs from 'fs/promises';
import path from 'path';
import { logger } from '../logger';

export interface OcrResult {
  text: string;
  confidence: number;
}

export class OcrService {
  /**
   * Reads an image file, preprocesses it, and extracts text using Tesseract OCR.
   * 
   * @param imagePath Absolute path to the local image file
   * @returns OcrResult containing normalized text and confidence score
   */
  static async extractText(imagePath: string): Promise<OcrResult> {
    const processedImagePath = `${imagePath}_processed.png`;

    try {
      logger.info(`Starting OCR process for image: ${imagePath}`);
      
      // 2, 3, 4. Sharp ile preprocess et (Grayscale uygula ve Contrast artır)
      await sharp(imagePath)
        .grayscale() // 3. Grayscale
        .normalize() // 4. Contrast artırır ve normalize eder (histogram eşitleme)
        // Alternatif olarak .linear(1.5, -(128 * 1.5 - 128)) gibi özel bir kontrast da kullanılabilir.
        .toFile(processedImagePath);

      logger.debug(`Image preprocessed successfully: ${processedImagePath}`);

      // 5. Tesseract OCR çalıştır (Türkçe + İngilizce destekle)
      const result = await Tesseract.recognize(
        processedImagePath,
        'eng+tur',
        { logger: m => logger.debug(`OCR Progress: ${m.status} ${Math.round(m.progress * 100)}%`) }
      );

      // 6. OCR text çıkar
      const rawText = result.data.text;
      
      // 7. OCR confidence döndür
      const confidence = result.data.confidence;

      // 8. OCR sonucu normalize et
      // Gereksiz satır sonlarını, ekstra boşlukları ve özel karakter kalıntılarını temizle
      const normalizedText = rawText
        .replace(/\n+/g, ' ') // Satır sonlarını boşluğa çevir
        .replace(/\s{2,}/g, ' ') // Birden fazla boşluğu teke düşür
        .trim();

      // 10. OCR sonucu logger ile loglansın
      logger.info(`OCR successfully extracted ${normalizedText.length} characters with ${confidence}% confidence.`);
      logger.debug(`Normalized OCR Text: \n${normalizedText}`);
      
      return {
        text: normalizedText,
        confidence
      };

    } catch (error) {
      logger.error(`OCR processing failed for ${imagePath}:`, error);
      throw error;
    } finally {
      // Temizlik işlemi
      try {
        await fs.unlink(processedImagePath);
        logger.debug(`Cleaned up processed temp file: ${processedImagePath}`);
      } catch (err) {
        // Eğer dosya oluşturulamadıysa silerken hata verebilir, yoksayılabilir.
      }
    }
  }
}
