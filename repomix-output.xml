import { WAMessage, downloadMediaMessage } from '@whiskeysockets/baileys';
import fs from 'fs/promises';
import path from 'path';
import crypto from 'crypto';
import { logger } from '../logger';

const MAX_FILE_SIZE_BYTES = 5 * 1024 * 1024; // 5 MB
const TEMP_DIR = path.resolve(process.cwd(), 'tmp');

export class ImageDownloaderService {
  /**
   * Initializes the service by ensuring the temporary directory exists.
   */
  static async init() {
    try {
      await fs.mkdir(TEMP_DIR, { recursive: true });
      logger.debug(`Temp directory ensured at: ${TEMP_DIR}`);
    } catch (error) {
      logger.error('Failed to create temp directory', error);
      throw error;
    }
  }

  /**
   * Downloads an image from a WhatsApp message to the local temp directory.
   * 
   * @param msg The original WhatsApp message object
   * @param imageMessage The specific image message details (for size checking etc.)
   * @param socket The Baileys socket instance (required for media download if re-upload is needed)
   * @returns The absolute path to the saved file
   */
  static async downloadImage(msg: WAMessage, imageMessage: any, socket: any): Promise<string> {
    // 3. File size kontrolü
    // fileLength is sometimes string, sometimes number depending on Baileys parsing
    const size = Number(imageMessage.fileLength || 0);
    
    if (size > MAX_FILE_SIZE_BYTES) {
      logger.warn(`Media rejected: File size (${size} bytes) exceeds maximum limit (${MAX_FILE_SIZE_BYTES} bytes).`);
      throw new Error('FILE_TOO_LARGE');
    }

    // 4. Invalid media reject (Check mimetype)
    const mimeType = imageMessage.mimetype || '';
    if (!mimeType.startsWith('image/')) {
      logger.warn(`Media rejected: Invalid mime type (${mimeType}). Expected image/*.`);
      throw new Error('INVALID_MEDIA_TYPE');
    }

    try {
      // Baileys media downloader
      const buffer = await downloadMediaMessage(
        msg,
        'buffer',
        {},
        { 
          logger: console as any,
          // If the media has been deleted from WA servers, we can request a re-upload if we pass the socket
          reuploadRequest: socket.updateMediaMessage 
        }
      );

      // Extract extension from mimetype (e.g., image/jpeg -> jpeg)
      const ext = mimeType.split('/')[1]?.split(';')[0] || 'jpg';
      
      // 2. Unique filename oluştur
      const fileName = `${crypto.randomUUID()}.${ext}`;
      const filePath = path.join(TEMP_DIR, fileName);

      // 1. Local temp klasörüne kaydet
      await fs.writeFile(filePath, buffer as Buffer);
      
      logger.info(`Image successfully saved to ${filePath}`);
      return filePath;

    } catch (error) {
      logger.error('Error downloading media message', error);
      throw error;
    }
  }
}
</file>

<file path="src/services/matchingService.ts">
import { logger } from '../logger';
import { ErrorRepository, ErrorRecord } from '../database/repositories/ErrorRepository';

export class MatchingService {
  /**
   * Cleans up text for general word-matching.
   */
  private static normalizeTextForSearch(text: string): string {
    return text
      .toLowerCase()
      .replace(/[^a-z0-9ğüşıöç\s]/g, ' ')
      .replace(/\s+/g, ' ')
      .trim();
  }

  /**
   * Searches the errors database by comparing DB records against the long OCR text.
   * 
   * @param ocrText The text extracted from the image
   * @returns The best matching ErrorRecord and its score or null
   */
  static async findBestMatch(ocrText: string): Promise<{record: ErrorRecord, score: number} | null> {
    try {
      if (!ocrText || ocrText.length < 5) {
        logger.warn('OCR text is too short to perform a meaningful search.');
        return null;
      }

      const errors = await ErrorRepository.getAllErrors();

      if (!errors || errors.length === 0) {
        logger.warn('No records found in the errors table to match against.');
        return null;
      }

      const rawOcrUpper = ocrText.toUpperCase();
      const normalizedOcr = this.normalizeTextForSearch(ocrText);
      const ocrWords = new Set(normalizedOcr.split(' ').filter(w => w.length > 2));

      let bestMatch: ErrorRecord | null = null;
      let highestScore = 0;

      for (const error of errors) {
        let currentScore = 0;

        // 1. EXACT CODE MATCH (Ultra High Confidence)
        // If the OCR text contains the exact error code (e.g. "E00016")
        if (error.code && error.code.length > 2) {
          if (rawOcrUpper.includes(error.code.toUpperCase())) {
            currentScore += 100; // Instant perfect match equivalent
          }
        }

        // 2. TITLE WORD OVERLAP
        if (error.title) {
          const titleWords = this.normalizeTextForSearch(error.title).split(' ').filter(w => w.length > 2);
          if (titleWords.length > 0) {
            let matchedWords = 0;
            for (const word of titleWords) {
              if (ocrWords.has(word) || normalizedOcr.includes(word)) {
                matchedWords++;
              }
            }
            // Add up to 50 points for title match
            currentScore += (matchedWords / titleWords.length) * 50;
          }
        }

        // 3. SUMMARY WORD OVERLAP
        if (error.summary) {
          const summaryWords = this.normalizeTextForSearch(error.summary).split(' ').filter(w => w.length > 3);
          if (summaryWords.length > 0) {
            let matchedWords = 0;
            for (const word of summaryWords) {
              if (ocrWords.has(word) || normalizedOcr.includes(word)) {
                matchedWords++;
              }
            }
            // Add up to 30 points for summary match
            currentScore += (matchedWords / summaryWords.length) * 30;
          }
        }

        if (currentScore > highestScore) {
          highestScore = currentScore;
          bestMatch = error;
        }
      }

      logger.info(`Best match evaluation: ID ${bestMatch?.id} with score ${highestScore.toFixed(2)}/180`);

      // Confidence Threshold: We need at least 30 points to consider it a valid match
      // (e.g., mostly matched the title, or got the exact code, or heavily matched the summary)
      if (highestScore < 30 || !bestMatch) {
        logger.warn(`Highest score (${highestScore.toFixed(2)}) is below the required threshold of 30. Discarding match.`);
        return null;
      }

      // We convert our positive score (0-180) to a distance metric (0 to 1) just to keep compatibility with the formatter.
      // Score 100+ = 0.0 distance (100% confidence)
      // Score 30 = ~0.7 distance (30% confidence)
      const simulatedDistance = Math.max(0, 1 - (highestScore / 100));

      return {
        record: bestMatch,
        score: simulatedDistance
      };

    } catch (err) {
      logger.error('Error during matching process:', err);
      return null;
    }
  }
}
