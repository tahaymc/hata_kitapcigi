# ============================================================
# WhatsApp Bot Başlatma Scripti
# Kullanım: .\start.ps1
# ============================================================

$RedisExe = Join-Path $PSScriptRoot "redis5\redis-server.exe"

# 1. Redis çalışıyor mu kontrol et
$redisRunning = Get-Process -Name "redis-server" -ErrorAction SilentlyContinue

if ($redisRunning) {
    Write-Host "✅ Redis zaten çalışıyor (PID: $($redisRunning.Id))" -ForegroundColor Green
} else {
    if (Test-Path $RedisExe) {
        Write-Host "🚀 Redis başlatılıyor..." -ForegroundColor Yellow
        Start-Process -FilePath $RedisExe -WindowStyle Hidden
        Start-Sleep -Seconds 2

        $redisRunning = Get-Process -Name "redis-server" -ErrorAction SilentlyContinue
        if ($redisRunning) {
            Write-Host "✅ Redis başlatıldı (PID: $($redisRunning.Id))" -ForegroundColor Green
        } else {
            Write-Host "❌ Redis başlatılamadı! redis5 klasörü mevcut mu?" -ForegroundColor Red
            exit 1
        }
    } else {
        Write-Host "❌ Redis bulunamadı: $RedisExe" -ForegroundColor Red
        Write-Host "   Lütfen önce redis5 klasörünü kontrol edin." -ForegroundColor Red
        exit 1
    }
}

# Onceki gorsel hash'lerini temizle (duplicate detection sifirla)
Write-Host "Gorsel cache temizleniyor..." -ForegroundColor DarkGray
$flushResult = & "$PSScriptRoot\redis5\redis-cli.exe" FLUSHALL 2>$null
if ($flushResult -eq "OK") {
    Write-Host "Cache temizlendi." -ForegroundColor DarkGray
}

# 2. WhatsApp oturumu sıfırla mı?
Write-Host ""
$resetSession = Read-Host "WhatsApp oturumunu sıfırla (yeni QR kodu)? [e/H]"
if ($resetSession -eq "e" -or $resetSession -eq "E") {
    $sessionDir = Join-Path $PSScriptRoot "auth_info_baileys"
    if (Test-Path $sessionDir) {
        Remove-Item -Recurse -Force $sessionDir
        Write-Host "🗑️  WhatsApp oturumu sıfırlandı." -ForegroundColor Yellow
    }
}

# 3. Botu başlat
Write-Host ""
Write-Host "🤖 Bot başlatılıyor... (Çıkmak için CTRL+C)" -ForegroundColor Cyan
Write-Host "============================================================" -ForegroundColor DarkGray
npm run dev
