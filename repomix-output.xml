import { supabase } from '../supabase';
import { logger } from '../../logger';

export interface ErrorRecord {
  id: any;
  title: string | null;
  code: string | null;
  category: string | null;
  summary: string | null;
  solution: string | null;
  solutionType: string | null;
  solutionSteps: string | null;
  date: string | null;
  viewCount: number | null;
  imageUrl: string | null;
  imageUrls: string[] | null;
  videoUrl: string | null;
  relatedPeople: string | null;
  assignee_id: string | null;
  sort_order: number | null;
  video_url: string | null;
  department_id: string | null;
}

export class ErrorRepository {
  /**
   * Fetches all error records from the database.
   * Useful for loading data into memory for Fuse.js fuzzy matching.
   */
  static async getAllErrors(): Promise<ErrorRecord[]> {
    try {
      const { data, error } = await supabase
        .from('errors')
        .select('*');

      if (error) {
        throw error;
      }

      return (data || []) as ErrorRecord[];
    } catch (err) {
      logger.error('Failed to fetch errors from repository:', err);
      throw err;
    }
  }

  // Future repository methods (e.g., getById, getByCategory) can be added here
}
