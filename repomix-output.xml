<file path="src/services/messageFormatter.ts">
import { ErrorRecord } from '../database/repositories/ErrorRepository';

/**
 * Strips HTML tags from a string, decodes HTML entities, and trims whitespace.
 */
function stripHtml(text: any): string {
  if (text === null || text === undefined || text === '') return '';
  
  if (Array.isArray(text)) {
    return text.map(item => stripHtml(item)).filter(Boolean).join('\n');
  }

  if (typeof text === 'object') {
    const parts: string[] = [];
    if (text.title) parts.push(`*${text.title}*`);
    if (text.text) parts.push(text.text);
    if (text.subSteps && Array.isArray(text.subSteps)) {
      text.subSteps.forEach((sub: any) => {
        if (sub.text) parts.push(`  • ${sub.text}`);
      });
    }
    return parts.map(p => stripHtml(p)).filter(Boolean).join('\n');
  }

  const str = String(text);
  return str
    .replace(/<[^>]*>/g, ' ')         // Remove HTML tags
    .replace(/&nbsp;/gi, ' ')         // Decode &nbsp;
    .replace(/&amp;/gi, '&')          // Decode &amp;
    .replace(/&lt;/gi, '<')           // Decode &lt;
    .replace(/&gt;/gi, '>')           // Decode &gt;
    .replace(/&quot;/gi, '"')         // Decode &quot;
    .replace(/&#39;/gi, "'")          // Decode &#39;
    .replace(/\s+/g, ' ')             // Collapse whitespace
    .trim();
}

export interface StepContent {
  text: string;
  images: string[];
}

export class MessageFormatterService {
  /**
   * Formats a clean success response when an error match is found.
   */
  static formatSuccessMessage(match: ErrorRecord, similarityScore: number): string {
    const lines: string[] = [];

    // Title / Code
    const title = stripHtml(match.title) || match.code || 'Bilinmeyen Hata';
    lines.push(`✅ *${title}*`);

    // Error code badge if available
    if (match.code && match.title) {
      lines.push(`🔖 Kod: \`${match.code}\``);
    }

    // Summary
    const summary = stripHtml(match.summary);
    if (summary) {
      lines.push(`📌 *Sebep:* ${summary}`);
    }

    // Main Solution
    const solution = stripHtml(match.solution);
    if (solution) {
      lines.push(`🛠 *Çözüm:* ${solution}`);
    }


    // Confidence score
    const confidencePercent = Math.min(100, Math.max(0, Math.round((1 - similarityScore) * 100)));
    lines.push(`📊 _Eşleşme: %${confidencePercent}_`);

    return lines.join('\n\n');
  }

  /**
   * Parses solutionSteps into a list of contents (text + images) to be sent step-by-step.
   */
  static getDetailedSteps(match: ErrorRecord): StepContent[] {
    if (!match.solutionSteps || !Array.isArray(match.solutionSteps)) return [];

    return match.solutionSteps.map((step: any) => {
      const images: string[] = [];
      if (step.imageUrl && step.imageUrl.startsWith('http')) {
        images.push(step.imageUrl);
      }
      
      if (step.subSteps && Array.isArray(step.subSteps)) {
        step.subSteps.forEach((sub: any) => {
          if (sub.imageUrl && sub.imageUrl.startsWith('http')) {
            images.push(sub.imageUrl);
          }
        });
      }

      let text = '';
      if (step.title) text += `*${stripHtml(step.title)}*\n`;
      if (step.text) text += stripHtml(step.text);
      
      if (step.subSteps && Array.isArray(step.subSteps)) {
        step.subSteps.forEach((sub: any) => {
          if (sub.text) text += `\n• ${stripHtml(sub.text)}`;
        });
      }

      return { text: text.trim(), images };
    }).filter(s => s.text || s.images.length > 0);
  }

  /**
   * Returns the main image URLs.
   */
  static getImageUrls(match: ErrorRecord): string[] {
    const urls: string[] = [];

    if (match.imageUrl && match.imageUrl.startsWith('http')) {
      urls.push(match.imageUrl);
    }
    if (Array.isArray(match.imageUrls)) {
      for (const u of match.imageUrls) {
        if (u && u.startsWith('http') && !urls.includes(u)) {
          urls.push(u);
        }
      }
    }

    return urls;
  }

  static getVideoUrl(match: ErrorRecord): string | null {
    const v = match.video_url || match.videoUrl;
    return v && v.startsWith('http') ? v : null;
  }

  static formatFallbackMessage(): string {
    return '❓ Gönderdiğiniz ekran görüntüsündeki hatayı veritabanımda bulamadım.\n\nDaha net bir fotoğraf göndermeyi deneyin veya ilgili departmana başvurun.';
  }

  static formatErrorMessage(): string {
    return '⚠️ Görselinizi işlerken teknik bir sorun oluştu. Lütfen daha sonra tekrar deneyin.';
  }
}
