<file path="src/services/duplicateDetection.ts">
import { redis } from '../config/redis';
import { supabase } from '../database/supabase';
import { logger } from '../logger';

// eslint-disable-next-line @typescript-eslint/no-var-requires
const hash = require('imghash');

const TTL_24_HOURS_SECONDS = 24 * 60 * 60; // 24 hours

export class DuplicateDetectionService {
  /**
   * Generates a perceptual hash and checks if it exists in Redis.
   * If it exists, returns true (isDuplicate).
   * If not, stores it in Redis and logs it to Supabase, then returns false.
   * 
   * @param imagePath The local path to the downloaded image
   * @param remoteJid The WhatsApp ID of the sender
   * @returns boolean indicating if the image is a duplicate
   */
  static async checkDuplicate(imagePath: string, remoteJid: string): Promise<boolean> {
    try {
      // 1. Görselden perceptual hash üret
      // Using a 16-bit hash length for better precision, default is 8
      const perceptualHash = await hash.hash(imagePath, 16);
      logger.debug(`Generated perceptual hash: ${perceptualHash}`);

      const redisKey = `image_hash:${perceptualHash}`;

      // 2. Redis cache içinde hash kontrol et
      const existingHash = await redis.get(redisKey);

      if (existingHash) {
        // 3. Aynı görsel daha önce işlendi ise cevap verme (true döndür)
        logger.info(`Duplicate image detected for hash: ${perceptualHash}`);
        return true;
      }

      // 4. Yeni hash ise işlem devam et, redis'e kaydet
      // 5. Redis TTL 24 saat olsun
      await redis.set(redisKey, 'processed', 'EX', TTL_24_HOURS_SECONDS);

      // 7. Hash database'e loglansın
      // We will save this asynchronously without awaiting to not block the pipeline
      this.logHashToDatabase(perceptualHash, remoteJid, imagePath).catch((err) => {
        logger.error('Failed to log hash to database:', err);
      });

      return false;

    } catch (error) {
      logger.error('Error during duplicate detection:', error);
      // If hashing or redis fails, we assume it's not a duplicate to not block processing
      // or we could throw the error depending on strictness. We will return false to proceed.
      return false;
    }
  }

  private static async logHashToDatabase(perceptualHash: string, remoteJid: string, imagePath: string) {
    const { error } = await supabase
      .from('image_hashes') // Make sure this table exists in Supabase
      .insert([
        { 
          hash: perceptualHash, 
          remote_jid: remoteJid, 
          local_path: imagePath,
          created_at: new Date().toISOString()
        }
      ]);

    if (error) {
      throw error;
    }
    logger.debug(`Successfully logged hash ${perceptualHash} to Supabase`);
  }
}
</file>

