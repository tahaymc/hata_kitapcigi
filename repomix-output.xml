<file path="src/services/pipelineService.ts">
import { Job } from 'bullmq';
import { getSocket } from '../whatsapp/connection';
import { ImageDownloaderService } from './imageDownloader';
import { DuplicateDetectionService } from './duplicateDetection';
import { OcrService } from './ocrService';
import { MatchingService } from './matchingService';
import { MessageFormatterService } from './messageFormatter';
import { logger } from '../logger';
import fs from 'fs/promises';

export class PipelineService {
  /**
   * Executes the entire end-to-end processing pipeline for an incoming WhatsApp image.
   * Tracks job status and handles errors at each stage.
   * 
   * @param job BullMQ Job containing remoteJid, msg, and imageMessage
   */
  static async execute(job: Job) {
    const { remoteJid, msg, imageMessage } = job.data;
    const socket = getSocket();
    let localPath: string | null = null;

    try {
      if (!socket) throw new Error('WhatsApp socket is not connected');

      // 1. Image Download
      await job.updateProgress(10);
      logger.info(`[Job ${job.id}] Step 1: Downloading image for ${remoteJid}`);
      localPath = await ImageDownloaderService.downloadImage(msg, imageMessage, socket);

      // 2. Duplicate Hash Check
      await job.updateProgress(30);
      logger.info(`[Job ${job.id}] Step 2: Checking duplicate hash`);
      const isDuplicate = await DuplicateDetectionService.checkDuplicate(localPath, remoteJid);
      
      if (isDuplicate) {
        logger.info(`[Job ${job.id}] Pipeline stopped: Duplicate image detected from ${remoteJid}`);
        await job.updateProgress(100);
        return { status: 'ignored', reason: 'duplicate' };
      }

      // 3. Preprocess & OCR & Normalize Text
      await job.updateProgress(50);
      logger.info(`[Job ${job.id}] Step 3: Running OCR and text normalization`);
      const ocrResult = await OcrService.extractText(localPath);

      if (ocrResult.confidence < 40) {
        logger.warn(`[Job ${job.id}] OCR confidence too low (${ocrResult.confidence}%). Sending fallback.`);
        await socket.sendMessage(remoteJid, { text: MessageFormatterService.formatFallbackMessage() }, { quoted: msg });
        await job.updateProgress(100);
        return { status: 'failed', reason: 'low_ocr_confidence' };
      }

      // 4. Supabase Match
      await job.updateProgress(70);
      logger.info(`[Job ${job.id}] Step 4: Matching with Supabase errors`);
      const matchResult = await MatchingService.findBestMatch(ocrResult.text);

      // 5. Reply
      await job.updateProgress(90);
      logger.info(`[Job ${job.id}] Step 5: Formatting and sending reply`);
      
      if (matchResult) {
        // 5a. Send main success message (text only, summary)
        const responseText = MessageFormatterService.formatSuccessMessage(matchResult.record, matchResult.score);
        logger.info(`[Job ${job.id}] Sending main reply to ${remoteJid}`);
        try {
          await socket.sendMessage(remoteJid, { text: responseText }, { quoted: msg });
        } catch (sendErr) {
          logger.error(`[Job ${job.id}] Failed to send main reply:`, sendErr);
        }

        // 5b. Send detailed steps sequentially
        const detailedSteps = MessageFormatterService.getDetailedSteps(matchResult.record);
        if (detailedSteps.length > 0) {
          logger.info(`[Job ${job.id}] Sending ${detailedSteps.length} detailed steps to ${remoteJid}`);
          for (const step of detailedSteps) {
            // Send step text
            if (step.text) {
              await socket.sendMessage(remoteJid, { text: `📍 ${step.text}` });
            }
            // Send step images
            for (const imgUrl of step.images) {
              try {
                await socket.sendMessage(remoteJid, {
                  image: { url: imgUrl },
                  caption: '📷 Adım görseli'
                });
              } catch (imgErr) {
                logger.warn(`[Job ${job.id}] Could not send step image: ${imgUrl}`);
              }
            }
          }
        }

        // 5c. Send main related images if they weren't in steps
        const mainImageUrls = MessageFormatterService.getImageUrls(matchResult.record);
        for (const imageUrl of mainImageUrls) {
          // Only send if not already included in steps (simple check)
          const isAlreadySent = detailedSteps.some(s => s.images.includes(imageUrl));
          if (!isAlreadySent) {
            try {
              await socket.sendMessage(remoteJid, {
                image: { url: imageUrl },
                caption: '📎 İlgili görsel',
              });
            } catch (imgErr) {
              logger.warn(`[Job ${job.id}] Could not send main image ${imageUrl}:`, imgErr);
            }
          }
        }

        // 5d. Send video link
        const videoUrl = MessageFormatterService.getVideoUrl(matchResult.record);
        if (videoUrl) {
          await socket.sendMessage(remoteJid, { text: `🎬 *Video Rehber:*\n${videoUrl}` });
        }
      } else {
        logger.info(`[Job ${job.id}] No match found, sending fallback to ${remoteJid}`);
        const fallbackText = MessageFormatterService.formatFallbackMessage();
        try {
          await socket.sendMessage(remoteJid, { text: fallbackText }, { quoted: msg });
          logger.info(`[Job ${job.id}] Fallback reply sent successfully`);
        } catch (sendErr) {
          logger.error(`[Job ${job.id}] Failed to send fallback reply:`, sendErr);
        }
      }

      await job.updateProgress(100);
      logger.info(`[Job ${job.id}] Pipeline execution completed successfully for ${remoteJid}`);
      return { status: 'completed', matched: !!matchResult };

    } catch (error: any) {
      logger.error(`[Job ${job.id}] Pipeline failed at processing stage:`, error);
      
      // Error handling for specific known errors
      if (error.message === 'FILE_TOO_LARGE' || error.message === 'INVALID_MEDIA_TYPE') {
        logger.warn(`[Job ${job.id}] Pipeline skipped due to invalid media.`);
        // No need to reply for invalid media, or we can send a specific error message
        return { status: 'ignored', reason: 'invalid_media' };
      }

      // For unexpected technical errors, notify the user
      if (socket) {
        try {
          await socket.sendMessage(remoteJid, { text: MessageFormatterService.formatErrorMessage() }, { quoted: msg });
        } catch (replyErr) {
          logger.error(`[Job ${job.id}] Failed to send error fallback message:`, replyErr);
        }
      }

      throw error; // Re-throw to trigger BullMQ retry logic
    } finally {
      // Cleanup Temp File
      if (localPath) {
        try {
          await fs.unlink(localPath);
          logger.debug(`[Job ${job.id}] Cleaned up temp file: ${localPath}`);
        } catch (cleanupErr) {
          logger.error(`[Job ${job.id}] Failed to clean up temp file ${localPath}:`, cleanupErr);
        }
      }
    }
  }
}
